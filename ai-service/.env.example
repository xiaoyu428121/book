# ===== 主模型：DeepSeek（OpenAI 兼容，额度用尽自动切备用）=====
# 注册 https://platform.deepseek.com 获取 sk- 开头的 Key
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ===== 备用模型 1：智谱 GLM（glm-4-flash 长期免费，零门槛）=====
# 注册 https://open.bigmodel.cn 获取 Key
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-flash

# ===== 备用模型 2：硅基流动 SiliconFlow（注册送约 2000 万免费 tokens）=====
# 注册 https://siliconflow.cn 获取 Key
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3

# ===== 备用模型 3：阿里云百炼 DashScope（通义千问，新用户免费额度）=====
# 注册 https://dashscope.console.aliyun.com 获取 Key
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-turbo

LLM_TEMPERATURE=0.7

# ===== MySQL（书籍语料 + 库存查询）=====
BOOK_DB_HOST=localhost
BOOK_DB_PORT=3306
BOOK_DB_USER=root
BOOK_DB_PASSWORD=0428
BOOK_DB_NAME=book_cycle

# ===== 检索与跨域 =====
TOP_K=5
CORS_ORIGINS=http://localhost:5173
