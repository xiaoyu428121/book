# =====================================================
# 智循书堂 · 通用 .gitignore
# =====================================================

# === Java / Maven ===
target/
*.class
*.jar
*.war
*.ear
.mvn/
mvnw
mvnw.cmd
.flattened-pom.xml

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.coverage
.cache
.pyright_cache/
.mypy_cache/
.ruff_cache/
venv/
env/
ENV/
.venv/
env.bak/
venv.bak/

# === Node / Vite / Vue ===
node_modules/
.pnp
.pnp.js
dist/
dist-ssr/
*.local

# === 各类 IDE / 编辑器 ===
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# === 日志 / 临时 / 上传 ===
logs/
*.log
*.log.*
*.pid
*.seed
*.pid.lock
backend/uploads/
backend/logs/

# === 环境变量 / 密钥（绝对不能入仓）===
.env
.env.local
.env.*.local
.env.development
.env.production
*.pem
*.key
secrets/
config/local.*

# === 构建/打包产物 ===
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache/
.sass-cache/
*.tsbuildinfo
.eslintcache
.stylelintcache

# === Source map（前端生产调试用，本地保留即可）===
# 注：保留 .map 文件不影响仓库体积，但生产环境一般不入仓。
# 如需保留前端源码可读性，删掉下面这行：
*.map

# === 数据库本地备份 ===
*.sql.bak
*.dump
db_backups/

# === 测试覆盖率 ===
coverage/
.nyc_output/
lcov.info

# === 系统文件 ===
.directory
.Trash-*
.fuse_hidden*
.nfs*
