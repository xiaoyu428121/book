# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/language_learning?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV=development

# AI Services (配置为mock,实际使用时替换为真实API密钥)
# LLM Provider: openai | claude | qwen
LLM_PROVIDER="mock"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
QWEN_API_KEY=""

# ASR/TTS Provider: xunfei | volcano
ASR_PROVIDER="mock"
TTS_PROVIDER="mock"
XUNFEI_APP_ID=""
XUNFEI_API_KEY=""
XUNFEI_API_SECRET=""
VOLCANO_ACCESS_TOKEN=""